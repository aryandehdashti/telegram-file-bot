# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_USER_ID=your_telegram_user_id

# File Handling
MAX_FILE_SIZE_MB=50
CHUNK_SIZE_MB=45
TEMP_DOWNLOAD_DIR=/tmp/telegram_bot_downloads
DOWNLOAD_TIMEOUT=300

# HTTP Server Configuration (for alternative downloads)
ENABLE_HTTP_SERVER=True
HTTP_SERVER_PORT=8080
HTTP_SERVER_HOST=0.0.0.0
VPS_HOST=your-vps-ip-or-domain
DOWNLOAD_LINK_EXPIRY_HOURS=24

# GitHub Fallback Configuration
GITHUB_TOKEN=your_github_token_for_fallback
GITHUB_REPO=your_username/your_repo
GITHUB_BRANCH=main

# Rate Limiting (optional)
ENABLE_RATE_LIMITING=False
MAX_DOWNLOADS_PER_HOUR=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/telegram_file_bot.log