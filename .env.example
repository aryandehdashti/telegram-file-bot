# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
ADMIN_USER_ID=your_telegram_user_id_for_admin_access

# File Handling
MAX_FILE_SIZE_MB=50
CHUNK_SIZE_MB=45
TEMP_DOWNLOAD_DIR=/tmp/telegram_bot_downloads
DOWNLOAD_TIMEOUT=300

# HTTP Server Configuration (for alternative downloads)
ENABLE_HTTP_SERVER=True
HTTP_SERVER_PORT=8080
HTTP_SERVER_HOST=0.0.0.0
VPS_HOST=your_vps_public_ip_or_domain_name
DOWNLOAD_LINK_EXPIRY_HOURS=24

# GitHub Storage Configuration
GITHUB_TOKEN=your_github_personal_access_token_with_repo_permissions
GITHUB_REPO=your_github_username/your_repository_name
GITHUB_BRANCH=main

# Rate Limiting (optional)
ENABLE_RATE_LIMITING=False
MAX_DOWNLOADS_PER_HOUR=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/telegram_file_bot.log