[Unit]
Description=Telegram File Download Bot (Combined)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/telegram-file-bot
Environment="PATH=/root/telegram-file-bot/venv/bin"
ExecStart=/root/telegram-file-bot/venv/bin/python run_all.py
Restart=always
RestartSec=10

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=telegram-file-bot

# Security
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target